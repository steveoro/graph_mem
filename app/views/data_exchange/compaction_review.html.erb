<% content_for :title, "Compaction Review" %>

<h1 class="text-2xl font-bold mb-4">Compaction Review</h1>

<% if @report %>
  <p class="text-sm text-gray-600 mb-4">
    Report #<%= @report.id %> — <%= @active_count %> active suggestion<%= "s" unless @active_count == 1 %>
    <span class="text-gray-400">(created <%= l(@report.created_at, format: :short) %>)</span>
  </p>
<% end %>

<% if @current_item && @confirm_action %>
  <div class="bg-yellow-50 border border-yellow-200 rounded p-4 mb-6">
    <h2 class="font-semibold mb-2">Confirm action</h2>
    <%= render "compaction_review_confirm", item: @current_item %>
  </div>
<% end %>

<% if @items && @items.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead>
        <tr>
          <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Kind</th>
          <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Source</th>
          <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Target</th>
          <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Details</th>
          <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @items.each do |item| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm">
              <span class="inline-flex items-center rounded bg-blue-100 px-2 py-1 text-xs font-medium text-blue-800">
                <%= item["kind"] %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm">
              <% if item["kind"] == "entity_merge" %>
                <strong><%= item["entity_a"]["name"] %></strong><br>
                <span class="text-gray-500"><%= item["entity_a"]["entity_type"] %> #<%= item["entity_a"]["entity_id"] %></span>
              <% elsif item["kind"] == "relationship_proposal" %>
                <strong><%= item["from_name"] %></strong><br>
                <span class="text-gray-500"><%= item["from_entity_type"] %> #<%= item["from_entity_id"] %></span>
              <% elsif item["kind"] == "orphan_parent" %>
                <strong><%= item["entity_name"] %></strong><br>
                <span class="text-gray-500"><%= item["entity_type"] %> #<%= item["entity_id"] %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm">
              <% if item["kind"] == "entity_merge" %>
                <strong><%= item["entity_b"]["name"] %></strong><br>
                <span class="text-gray-500"><%= item["entity_b"]["entity_type"] %> #<%= item["entity_b"]["entity_id"] %></span>
              <% elsif item["kind"] == "relationship_proposal" %>
                <strong><%= item["to_name"] %></strong><br>
                <span class="text-gray-500"><%= item["to_entity_type"] %> #<%= item["to_entity_id"] %></span>
              <% elsif item["kind"] == "orphan_parent" %>
                <% if item["suggested_parents"].present? %>
                  <% item["suggested_parents"].first(3).each do |parent| %>
                    <div class="mb-1">
                      <strong><%= parent["project_name"] %></strong>
                      <span class="text-gray-500">#<%= parent["project_id"] %></span>
                      <span class="text-xs text-gray-400">(score <%= parent["score"] %>)</span>
                    </div>
                  <% end %>
                <% else %>
                  <span class="text-gray-400">No suggestions</span>
                <% end %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600">
              <% if item["kind"] == "entity_merge" %>
                Cosine distance: <%= item["cosine_distance"] %>
              <% elsif item["kind"] == "relationship_proposal" %>
                <span class="font-medium"><%= item["relation_type"] %></span>
                <span class="text-gray-400">— <%= item["confidence_band"] %></span>
                <span class="text-gray-400">(score <%= item["score"] %>)</span>
                <% if item["explanation"].present? %>
                  <p class="text-xs mt-1"><%= item["explanation"] %></p>
                <% end %>
              <% elsif item["kind"] == "orphan_parent" && item["error"].present? %>
                <p class="text-xs text-red-600"><%= item["error"] %></p>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm">
              <div class="flex gap-2">
                <%= button_to "Approve", compaction_review_action_data_exchange_index_path(item_id: item["id"], page: params[:page], review_action: "approve"), method: :post, class: "rounded bg-green-600 px-3 py-1 text-white hover:bg-green-700" %>
                <%= button_to "Reject", compaction_review_action_data_exchange_index_path(item_id: item["id"], page: params[:page], review_action: "reject"), method: :post, class: "rounded bg-gray-200 px-3 py-1 text-gray-700 hover:bg-gray-300" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%= paginate @items %>
  </div>
<% else %>
  <p class="text-gray-500">No active compaction review suggestions.</p>
<% end %>

<div class="mt-6">
  <%= link_to "Back to dashboard", root_path, class: "text-sm text-blue-600 hover:underline" %>
</div>
