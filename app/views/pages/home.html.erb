<div class="container mx-auto">
  <h1 class="text-3xl font-bold mb-6 text-center">GraphMem - Knowledge Graph Visualization - v<%= GraphMem::VERSION %></h1>

  <%= render "search/form", vector_available: @vector_available %>

  <div data-controller="graph" class="w-full border rounded-lg shadow-lg bg-gray-50" style="height: 72vh;">
    <div data-graph-target="container" style="width: 100%; height: 100%;"></div>
  </div>

  <p class="mt-6 text-sm text-gray-600 text-center">
    <i><small>Interactive graph powered by Cytoscape.js and Stimulus.</small></i>
  </p>
</div>
